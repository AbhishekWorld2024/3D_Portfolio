# LLM provider: "ollama" (free, local — default) or "anthropic" (cloud)
LLM_PROVIDER=ollama

# --- Ollama (free, local). Install from https://ollama.com, then: ollama pull llama3.2 ---
OLLAMA_HOST=http://localhost:11434
# llama3.2 (3B) is fast; use a bigger model like llama3 (8B) for higher quality
OLLAMA_MODEL=llama3.2

# --- Anthropic (only needed if LLM_PROVIDER=anthropic) ---
# Get a key at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

PORT=3001
