# LLM provider: "groq" (free cloud, for deployment), "ollama" (free local, for dev),
# or "anthropic" (paid cloud).
LLM_PROVIDER=ollama

# --- Groq (free + fast cloud — use this in production / Vercel) ---
# Get a free key at https://console.groq.com/keys
# GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (free, local). Install from https://ollama.com, then: ollama pull llama3.2:1b ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# --- Anthropic (paid cloud, optional) ---
# Get a key at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

PORT=3001
